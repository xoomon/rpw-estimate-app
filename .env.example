# Copy this file's contents into Vercel's Environment Variables settings.
# Do not commit a real .env file with your actual key to version control.

# Your Resend API key (from resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be an address on a domain you've verified in Resend, e.g. estimates@raleighpowerwash.com
FROM_EMAIL=Raleigh Power Wash Estimates <estimates@raleighpowerwash.com>

# Where estimate submissions get delivered
TO_EMAIL=info@raleighpowerwash.com

# Passcode required to view/edit the rate sheet at /admin.html — choose your own
ADMIN_PASSCODE=rpw-admin!
